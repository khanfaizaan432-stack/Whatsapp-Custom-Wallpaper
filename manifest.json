{
  "manifest_version": 3,
  "name": "WhatsApp Themes",
  "description": "Per-chat wallpapers (image/video), bubble colours, fonts, blur effects and custom themes for WhatsApp Web.",
  "version": "1.1.0",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js", "content-patch.js", "content-repair-trigger.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WhatsApp Themes"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
